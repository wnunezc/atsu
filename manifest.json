{
  "manifest_version": 3,
  "name": "ATSU",
  "description": "Advanced Toolkit for Stack Overflow and Stack Exchange users, with local diagnostics, comment assistance, color profiles, portable settings, and question-status badges.",
  "version": "1.0.0",
  "author": "Walter Nuñez",
  "icons": {
    "32": "src/media/32.png",
    "48": "src/media/48.png",
    "64": "src/media/64.png",
    "128": "src/media/128.png"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://stackoverflow.com/*",
    "https://*.stackoverflow.com/*",
    "https://serverfault.com/*",
    "https://*.serverfault.com/*",
    "https://superuser.com/*",
    "https://*.superuser.com/*",
    "https://askubuntu.com/*",
    "https://*.askubuntu.com/*",
    "https://stackapps.com/*",
    "https://*.stackapps.com/*",
    "https://*.stackexchange.com/*",
    "https://mathoverflow.net/*",
    "https://*.mathoverflow.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "src/html/popup.html",
    "default_title": "ATSU - Stack Exchange Toolkit",
    "default_icon": {
      "32": "src/media/32.png",
      "48": "src/media/48.png",
      "64": "src/media/64.png",
      "128": "src/media/128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://stackoverflow.com/*",
        "https://*.stackoverflow.com/*",
        "https://serverfault.com/*",
        "https://*.serverfault.com/*",
        "https://superuser.com/*",
        "https://*.superuser.com/*",
        "https://askubuntu.com/*",
        "https://*.askubuntu.com/*",
        "https://stackapps.com/*",
        "https://*.stackapps.com/*",
        "https://*.stackexchange.com/*",
        "https://mathoverflow.net/*",
        "https://*.mathoverflow.net/*"
      ],
      "js": [
        "src/js/shared/config.js",
        "src/js/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
